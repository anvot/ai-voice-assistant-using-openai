#Usernames, Passwords
username_1 = "user1"
password_1 = "pass1"


# OpenAI API key
api_key = "**************"  # YOUR OPENAI API KEY (created in your OPENAI account)!!!!

# OpenAI Assistant
assistant = "***********"  # YOUR ASSISTANT ID in OPENAI (created in your OPENAI account)!!!!

# When working through a proxy server, uncomment one of the following lines
#proxies = {"http://": "http://localhost:1080", "https://": "http://localhost:1080"}
#proxies = http://localhost:1080

temperature = 1.0                                     # 0.0 ... 2.0
top_p = 1.0                                           # 0.0 ... 1.0
model_name = "gpt-4o-mini"                            # "gpt-3.5-turbo", "gpt-4-turbo", "gpt-4o-mini", "gpt-4o", "gpt-4.1-mini"
assistants_model = "gpt-4.1-mini"                    # "gpt-3.5-turbo", "gpt-4-turbo", "gpt-4o-mini", "gpt-4o", "gpt-4.1-mini"
assistant_name = "Sales_Agent"
assistant_response_format = "auto"                    # "auto", "text", "json_object", "json_schema"
transcription_model="gpt-4o-transcribe"               # "whisper-1", "gpt-4o-transcribe", gpt-4o-mini-transcribe
tts_model = "tts-1"                                   # "tts-1", "tts-1-hd", "gpt-4o-mini-tts"
voice = "nova"                                        # "nova", "alloy", "echo", "fable", "onyx", "shimmer"
audio_response_format = "opus"                        # mp3, opus, aac, flac, wav, pcm
speech_speed = 1.0                                    # 0.25 ... 4.0
dialog_window = 16                                    # The number of messages from the dialogue history, starting with the last one, loaded when the assistant starts (if 0, all messages in the dialogue are loaded)

plugins = weather,web_search                          # plugins used

#MongoDB name
MONGODB_NAME=ai_voice_assistant
#MongoDB IP
MONGODB_IP=127.0.0.1
# MongoDB port
MONGODB_PORT=27017
# MongoDB username
MONGODB_USERNAME=assistant  # YOUR DATABASE NAME is Mongo!!!!!!!
# MongoDB password
MONGODB_PASSWORD=assistant  # YOUR Mongo DATABASE PASSWORD!!!!!!!

